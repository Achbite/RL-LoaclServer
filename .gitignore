参考文档

# 临时检查文件
_check_output.txt

# ---- 运行时日志（精确到各子项目运行时目录，不影响 src/log/ 源码）----
/TrainClient/log/
/AIServer/log/
/RL-Learner/logs/
*.log

# ---- 运行时数据（回放记录 + 指标数据）----
/TrainClient/log/viz/*.jsonl
/RL-Learner/logs/metrics/*.jsonl

# ---- 模型二进制文件（递归匹配所有层级）----
**/*.onnx
**/*.pt
**/*.pth
# 保留 .gitkeep 占位文件
!**/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
*.egg

# C++ 构建产物
build/
cmake-build-*/
*.o
*.obj
*.exe
*.out
*.a
*.lib
*.so
*.dll

# Protobuf 生成文件
*_pb2.py
*_pb2_grpc.py
*.pb.cc
*.pb.h

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker
/tmp/dockerd.log
.docker_build_hash
.docker_build_hash_*

# ccache 编译缓存
.ccache/

.codebuddy